# ══════════════════════════════════════════════════════════════════
# FRONTEND — Vite build-time variables
# Set these in Hostinger's Environment Variables panel.
# They are baked into the JS bundle during `npm install` (postinstall).
# ══════════════════════════════════════════════════════════════════

VITE_SUPABASE_URL=https://hlgrvgldcgvelrvutlne.supabase.co
VITE_SUPABASE_ANON_KEY=
# Since API is now served by the same Express app, /api works without a full URL.
# Set to /api in Hostinger — no domain needed.
VITE_API_URL=/api


# ══════════════════════════════════════════════════════════════════
# SERVER — Express runtime variables
# Set these in Hostinger's Environment Variables panel.
# Used by the Node.js server at runtime (not baked into the build).
# ══════════════════════════════════════════════════════════════════

# ── MySQL Database ─────────────────────────────────────────────────
API_DB_HOST=
API_DB_NAME=
API_DB_USER=
API_DB_PASS=

# ── Supabase JWT verification ──────────────────────────────────────
# API_SUPABASE_URL — used to fetch JWKS for ES256/RS256 token verification
API_SUPABASE_URL=https://hlgrvgldcgvelrvutlne.supabase.co
# API_SUPABASE_JWT_SECRET — used for HS256 token verification
API_SUPABASE_JWT_SECRET=

# ── File upload paths ──────────────────────────────────────────────
# Absolute filesystem paths on Hostinger where files are written.
# The /uploads URL is served as static files by Express from API_UPLOAD_DIR.
API_UPLOAD_DIR=/home/u142852704/domains/darkslategray-squirrel-171439.hostingersite.com/public_html/uploads/
API_UPLOAD_URL=https://darkslategray-squirrel-171439.hostingersite.com/uploads/

API_STAGING_UPLOAD_DIR=/home/u142852704/domains/darkslategray-squirrel-171439.hostingersite.com/public_html/uploads/data/staging/
API_STAGING_UPLOAD_URL=https://darkslategray-squirrel-171439.hostingersite.com/uploads/data/staging/

API_PROD_UPLOAD_DIR=/home/u142852704/domains/darkslategray-squirrel-171439.hostingersite.com/public_html/uploads/data/prod/
API_PROD_UPLOAD_URL=https://darkslategray-squirrel-171439.hostingersite.com/uploads/data/prod/

# ── CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Include localhost for local dev if needed.
API_ALLOWED_ORIGINS=https://darkslategray-squirrel-171439.hostingersite.com
